# ============================================================================
# frontend.frozen.kvx
# Sidiora.fun — Frontend (apps/web) Production-Readiness Remediation Spec
# ----------------------------------------------------------------------------
# format       = "sectioned-kvx (dense key=value, double-quoted string values)"
# version      = "0.1.0"
# status       = "frozen-audit (current-state grounded; remediation locked)"
# scope        = "FRONTEND ONLY — apps/web + the 8 shared SDK packages it consumes"
# authored     = "2026-06-21"
# author       = "did:matrix:cursor-agent:d205e18de628e38d (pair-programmer)"
# checklist    = "/sidiora/client/production_checklist.md (18 domains, 100k+ users)"
# north_star   = "Survive six-figure concurrent users on a real-time financial UI"
# program_note = "First microservice of the broader /sidiora system rebuild;"
#                "subsequent sessions walk the remaining services one by one."
# ============================================================================

[meta.house_rules]
RT_tag        = "[RT] items are extra-critical: real-time / financial / trading paths"
severity      = "P0=launch-blocker, P1=must-fix-pre-launch, P2=hardening, P3=nice-to-have"
file_anchors  = "every task cites the real file(s) it touches; paths are absolute"
grounding     = "current-state lines below were read from source, not assumed"
no_regression = "do NOT weaken existing tests/guards; add, don't subtract"

# ============================================================================
# SECTION 0 — STACK GROUND TRUTH (verified from source)
# ============================================================================
[stack]
framework      = "Next.js 15.3.8 (App Router) + React 19 + TypeScript 5.7 strict"
monorepo       = "pnpm@9.15 workspaces: apps/web + packages/{candles,indexer,metadata,ranking,stats,users,launchpad_v3,components,ui-tokens,fonts}-core"
dev            = "next dev --turbopack --port 3050"
output         = "standalone (Docker) — apps/web/next.config.ts"
deploy         = "Railway (railway.json + Dockerfile); nginx TLS terminator fronts WS at /ws/{service}"
styling        = "TailwindCSS v4 (@tailwindcss/postcss); fonts = Manrope .otf via raw @font-face"
web3           = "wagmi 2 + viem 2; chain=Paxeer (id 125); cookie-storage SSR; embedded wallet (Supabase: email/google/github/X)"
data_layer     = "@tanstack/react-query v5 (proxied via /api/sdk/*), Zustand 5 (UI state)"
realtime       = "raw WebSocket managers (chat-ws.ts); candles WS via getServiceWsUrl('candles')"
error_report   = "@sentry/nextjs INSTALLED but NOT WIRED + zero-dep beacon fallback"
upstreams      = "9 Railway microservices (candles/indexer/metadata/ranking/stats/users/chat/livestream/pnl) all proxied server-side"

# ============================================================================
# SECTION 1 — RENDERING & ARCHITECTURE
# ============================================================================
[domain.01_rendering]
current.layout            = "src/app/layout.tsx is async, awaits headers()/cookies() -> entire tree is request-dynamic by default"
current.segment_files     = "ONLY root-level loading.tsx / error.tsx / not-found.tsx exist (src/app/*); no per-segment ones"
current.segment_config    = "NO route segment config anywhere (no dynamic/revalidate/runtime/fetchCache exports)"
current.client_boundary   = "AppProviders is 'use client' and wraps AppShell -> client tree starts very high; RSC benefit largely lost below shell"
current.ppr               = "Partial Prerendering NOT enabled"
current.runtime           = "no per-route runtime selection (all default Node)"

T01.1.severity = "P1"
T01.1.action   = "Add explicit route segment config per route group (dynamic/revalidate/runtime/fetchCache); classify each /app route as static|ISR|dynamic and stop accidental full-dynamic"
T01.1.files    = "src/app/**/page.tsx, src/app/**/layout.tsx"

T01.2.severity = "P1"
T01.2.action   = "Add per-segment loading.tsx + error.tsx + not-found.tsx for token/, terminal/, swap/, profile/, live/, meta-ag/, pnl/, rewards/ so one slow/failed view never blanks the app"
T01.2.files    = "src/app/{token,terminal,swap,profile,live,meta-ag,pnl,rewards}/**"

T01.3.severity = "P2"
T01.3.action   = "Push 'use client' down to leaves: split AppShell static chrome (RSC) from interactive islands; audit which providers truly need to wrap children"
T01.3.files    = "src/ui/providers/app-providers.tsx, src/shell/app-shell.tsx"

T01.4.severity = "P2"
T01.4.action   = "Evaluate PPR (static shell + dynamic holes) for home/token landing once Next 15 canary stabilises; gate behind experimental flag"
T01.4.files    = "apps/web/next.config.ts"

# ============================================================================
# SECTION 2 — PERFORMANCE & CORE WEB VITALS
# ============================================================================
[domain.02_performance]
current.virtualization = "PRESENT — src/ui/common/bounded-list.tsx uses @tanstack/react-virtual (good; verify ALL long lists use it: orderbook, trades, holders, positions tables)"
current.fonts          = "Manrope loaded via raw @font-face (.otf, opentype) in globals.css; NOT next/font; NOT subsetted; .otf is heavier than .woff2"
current.font_tokens    = "globals.css still references --font-geist-sans / --font-geist-mono (STALE template leftover; unused)"
current.bundle_budget  = "NO @next/bundle-analyzer, NO per-route KB budget, NO CWV budget in CI (no CI present)"
current.images         = "next/image configured w/ remotePatterns + dangerouslyAllowSVG sandboxed (good)"

T02.1.severity = "P1"
T02.1.action   = "Migrate fonts to next/font/local with .woff2 + subsetting + zero-CLS; remove stale --font-geist-* vars; wire font CSS vars into Tailwind theme"
T02.1.files    = "src/app/globals.css, src/app/layout.tsx, public/fonts/*"

T02.2.severity = "P1"
T02.2.action   = "Add @next/bundle-analyzer + per-route JS budget; audit heavy deps (rc-dock, embla, hls.js, framer+motion BOTH installed — dedupe to one) and dynamic-import below-fold (charts, terminal docking, video)"
T02.2.files    = "apps/web/next.config.ts, apps/web/package.json"
T02.2.note     = "package.json ships BOTH framer-motion@12 and motion@12 (root) — pick one to cut bundle"

T02.3.severity = "P1 [RT]"
T02.3.action   = "Audit every high-frequency list (terminal Table, ticker, trades, top-holders) confirms virtualization; batch WS-driven re-renders via requestAnimationFrame, never setState-per-tick"
T02.3.files    = "src/widgets/terminal/**, src/widgets/trading/**, src/shell/platform-metrics.tsx"

T02.4.severity = "P2 [RT]"
T02.4.action   = "Move CBOR/JSON decode + aggregation off main thread (Web Worker) for candle/orderbook hot paths"
T02.4.files    = "src/widgets/trading/udf-datafeed.ts, src/core/clients/candle-stats.ts"

T02.5.severity = "P2"
T02.5.action   = "Enforce CWV budgets (LCP<2.5s, INP<200ms, CLS<0.1, TTFB<800ms) in CI; fail build on regression"
T02.5.files    = "(new) .github/workflows/ci.yml"

# ============================================================================
# SECTION 3 — CACHING & DATA FETCHING
# ============================================================================
[domain.03_caching]
current.proxy        = "GOOD — src/app/api/sdk/[service]/[...path]/route.ts sets per-service Cache-Control s-maxage + stale-while-revalidate; hides upstream URLs"
current.bff          = "src/app/api/bff/token/[pool]/route.ts s-maxage=5 swr=10 (good for token page)"
current.rq_defaults  = "query-provider.tsx: staleTime 10s, retry 1, refetchOnWindowFocus+Reconnect true"
current.shared_cache = "NONE — no Redis/Upstash; each Next instance caches independently"
BUG.users_cache      = "CRITICAL: SDK proxy CACHE_TTL.users=3600 but the inline comment says 'no-store — personal profile data, must not be stale' — personal data is being cached publicly for 1h (privacy + staleness)"
BUG.realtime_cache   = "chat/livestream TTL=3600 commented 'no cache — realtime' but value caches 1h; pnl TTL=1 commented '30s'; comments contradict values throughout"

T03.1.severity = "DONE"
T03.1.action   = "[DONE 2026-06-21] Fixed SDK-proxy CACHE_TTL: users/chat/livestream/pnl set to 0 (no-store); ranking comment 1min->30s reconciled; SWR pruned to cacheable services; added AUTH_HEADERS check so any authed/personalized request is forced no-store (never shared-cached). route.ts:29-58,73-77,100-118"
T03.1.files    = "src/app/api/sdk/[service]/[...path]/route.ts:29-48"

T03.2.severity = "P1 [RT]"
T03.2.action   = "Define explicit stale-data tolerance per data type (prices/balances = never stale; metadata = long); document policy; ensure Cache-Control Vary/auth-aware so authed responses are not shared-cached"
T03.2.files    = "src/app/api/sdk/[service]/[...path]/route.ts, src/core/query-keys.ts"

T03.3.severity = "P2"
T03.3.action   = "Add shared server cache (Upstash/Redis) for cross-instance ISR coordination + rate-limit counters; avoid thundering-herd revalidation at scale"
T03.3.files    = "(new) src/core/cache/redis.ts"

T03.4.severity = "P2"
T03.4.action   = "Wire revalidateTag/revalidatePath to mutations (token create, profile edit); document tags"
T03.4.files    = "src/widgets/create/create-wizard.tsx, src/app/api/**"

# ============================================================================
# SECTION 4 — STATE MANAGEMENT
# ============================================================================
[domain.04_state]
current.split        = "Server state = TanStack Query; UI state = Zustand; wallet = wagmi cookie-storage (good separation)"
current.url_state    = "PARTIAL — verify selected market/tab/filters live in URL for shareable/restorable state"
current.optimistic   = "src/hooks/tx/use-optimistic-receipt.ts exists (good start)"
current.hydration    = "layout reads cookies server-side -> wagmi cookieToInitialState (correct SSR-safe pattern)"

T04.1.severity = "P1 [RT]"
T04.1.action   = "Harden optimistic updates with explicit rollback on failure for order placement/cancel/swap; surface rollback in toasts"
T04.1.files    = "src/hooks/tx/use-optimistic-receipt.ts, src/widgets/meta-ag/order-form.tsx, src/widgets/swap/swap-panel.tsx"

T04.2.severity = "P2"
T04.2.action   = "Move shareable state (selected token, terminal tab, filters) to URL searchParams as source of truth"
T04.2.files    = "src/page-modules/**, src/widgets/terminal/**"

T04.3.severity = "P2"
T04.3.action   = "Audit Zustand store scoping — ensure no app-wide store causes global re-renders on hot ticks"
T04.3.files    = "src/**/*store*.ts"

# ============================================================================
# SECTION 5 — REAL-TIME / WEBSOCKET LAYER  [RT]
# ============================================================================
[domain.05_realtime]
current.chat_ws        = "STRONG baseline — src/core/clients/chat-ws.ts: single multiplexed conn, consumer map, exp-backoff+jitter (cap 30s), ping 25s, circuit breaker (15 attempts), resubscribe-on-reconnect, clean 4001/4003 no-retry"
current.candles_ws     = "WEAK — candles-core SDK is HTTP-only (generated); no dedicated candle WS manager mirroring chat-ws; realtime candles likely polled"
GAP.heartbeat_deadconn = "ping is fire-and-forget; no pong-timeout -> dead-connection detection (server silently gone is not noticed until TCP close)"
GAP.sequence_gap       = "NO sequence/gap detection -> missed messages on orderbook/trades go undetected (CRITICAL for financial correctness)"
GAP.snapshot_delta     = "NO snapshot+delta resync model on reconnect (orderbook can drift)"
GAP.backpressure       = "NO coalescing/drop of stale ticks; high-volume bursts can flood main thread"
GAP.visibility         = "NO Page Visibility throttle/pause when tab hidden"
GAP.sse_fallback       = "NO SSE fallback where corporate proxies block WS"
GAP.precision          = "FLOAT money math — see domain 02/15; prices/balances pass through Number()"

T05.1.severity = "P0 [RT]"
T05.1.action   = "Build a shared WS connection-manager abstraction (generalise chat-ws.ts) with: pong-timeout dead-conn detection, monotonic sequence numbers + gap detection, snapshot+delta resync on reconnect, bounded queue with stale-tick coalescing (backpressure)"
T05.1.files    = "(new) src/core/realtime/ws-manager.ts (refactor chat-ws.ts onto it)"

T05.2.severity = "P0 [RT]"
T05.2.action   = "Implement candle/market WS consumer on the new manager (initial REST snapshot then incremental diffs); replace any polling on the trading terminal"
T05.2.files    = "src/widgets/trading/udf-datafeed.ts, src/core/clients/candle-stats.ts, src/core/sdk-config.ts:62-69"

T05.3.severity = "P1 [RT]"
T05.3.action   = "Add Page Visibility awareness: pause/throttle non-critical streams when document.hidden; full resync on re-show"
T05.3.files    = "src/core/realtime/ws-manager.ts"

T05.4.severity = "P2 [RT]"
T05.4.action   = "Add SSE fallback transport for environments where WS is blocked"
T05.4.files    = "src/core/realtime/ws-manager.ts"

