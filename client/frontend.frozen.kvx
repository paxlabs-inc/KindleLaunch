GAP.hsts             = "NO Strict-Transport-Security header"
GAP.nosniff          = "NO X-Content-Type-Options: nosniff"
GAP.referrer         = "NO Referrer-Policy header"
current.permissions  = "Permissions-Policy set (clipboard only)"
current.xfo          = "X-Frame-Options SAMEORIGIN only when no wallet origin (correct deference to frame-ancestors)"
GAP.sri              = "NO Subresource Integrity for external/charting scripts"
